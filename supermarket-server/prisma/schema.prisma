generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id                 String   @id @default(uuid())
  name               String
  description        String?
  price              Float
  discountPercentage Float    @default(0)
  stockQuantity      Int
  imageUrl           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Order {
  id            String      @id @default(uuid())
  customerName  String
  customerPhone String
  items         Json
  totalAmount   Float
  status        OrderStatus @default(PENDING)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String
}
